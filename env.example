# ─────────────────────────────────────────────────────────────────
#  NaijaRights — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────

# PostHog Analytics (https://posthog.com — free up to 1M events/month)
#
# How to get your key:
#   1. Sign up at https://posthog.com
#   2. Create a new project
#   3. Go to Project Settings → Project API Key
#   4. Copy the key that starts with "phc_"
#
# NEXT_PUBLIC_ prefix is required — it makes the variable available
# in the browser / Android WebView at build time.

NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PostHog region — use us.i.posthog.com (US) or eu.i.posthog.com (EU)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
