# ─────────────────────────────────────────────────────────────────
#  NaijaRights — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  .env.local is gitignored and never committed.
# ─────────────────────────────────────────────────────────────────

# PostHog Analytics (https://posthog.com — free up to 1M events/month)
#
# How to get your key:
#   1. Sign up at https://posthog.com
#   2. Create a new project
#   3. Go to Project Settings → Project API Key
#   4. Copy the key that starts with "phc_"
#
# NEXT_PUBLIC_ prefix is required — it makes the variable available
# in the browser / Android WebView at build time.

NEXT_PUBLIC_POSTHOG_KEY=phc_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# PostHog region — use us.i.posthog.com (US) or eu.i.posthog.com (EU)
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ─────────────────────────────────────────────────────────────────
# Firebase Cloud Messaging (Push Notifications)
# Project: naijarights-001
#
# How to get these values:
#   1. Go to https://console.firebase.google.com → naijarights-001
#   2. Project Settings → General → Your apps → Add Web App (if not done)
#   3. Copy the firebaseConfig values below
#   4. Project Settings → Cloud Messaging → Web Push certificates
#      → Generate key pair → copy the VAPID key
# ─────────────────────────────────────────────────────────────────

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAQKlPotf1QfOtFa46iD5H9pkHOk-wWDu4
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=naijarights-001.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=naijarights-001
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=naijarights-001.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=403289087014
NEXT_PUBLIC_FIREBASE_APP_ID=1:403289087014:web:XXXXXXXXXXXXXXXX   # replace with your web app ID
NEXT_PUBLIC_FIREBASE_VAPID_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX  # from Cloud Messaging → Web Push certs